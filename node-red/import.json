    {
        "id": "c8d2dd95d7815bb6",
        "type": "function",
        "z": "01122f8bf11e4369",
        "name": "Parse & Route",
        "func": "var data = msg.payload;\nflow.set('lastSoil', data.soil);\nflow.set('lastTemp', data.temp);\nflow.set('lastHum', data.humidity);\n\n// Statuses for Soil and Air\nvar soilS = \"✅ Đất am tốt\";\nif (data.soil < 30) soilS = \"🚨 Đất khô hạn\";\nelse if (data.soil < 45) soilS = \"⚠️ Đất hơi khô\";\n\nvar tempS = \"✅ Nhiệt độ ổn định\";\nif (data.temp > 35) tempS = \"🚨 Nhiệt độ quá cao\";\nelse if (data.temp < 18) tempS = \"❄️ Nhiệt độ thấp\";\n\nvar humS = \"✅ Độ ẩm KK tốt\";\nif (data.humidity < 40) humS = \"💨 Không khí khô\";\n\n// Water flow rate simulator (if pump is on, flow is ~0.1L/s)\nvar flowRate = data.pump ? 0.1 : 0;\n\nreturn [\n    {payload: data.soil, topic: 'soil'},\n    {payload: data.temp, topic: 'temp'},\n    {payload: data.humidity, topic: 'humidity'},\n    {payload: data.pump ? '🔴 ĐANG BƠM' : '🟢 BƠM ĐANG TẮT', topic: 'pump_status'},\n    {payload: soilS, topic: 'soil_status'},\n    {payload: tempS + \" | \" + humS, topic: 'air_status'},\n    {payload: flowRate, topic: 'water_flow'}\n];",
        "outputs": 7,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1040,
        "y": 360,
        "wires": [
