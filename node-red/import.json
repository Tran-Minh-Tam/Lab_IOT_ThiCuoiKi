    {
        "id": "parse_water_chart",
        "type": "function",
        "z": "01122f8bf11e4369",
        "name": "Parse Water daily",
        "func": "var d = msg.payload;\nvar waterLog = flow.get('waterLog') || [];\nvar today = new Date().toLocaleDateString('vi-VN', {day:'2-digit',month:'2-digit'});\n\nvar found = false;\nfor (var i = 0; i < waterLog.length; i++) {\n    if (waterLog[i].date === today) {\n        waterLog[i].liters = d.daily;\n        found = true;\n        break;\n    }\n}\nif (!found) {\n    waterLog.push({date: today, liters: d.daily});\n}\nif (waterLog.length > 7) waterLog.shift();\nflow.set('waterLog', waterLog);\n\nvar chartData = [{\n    \"series\": [\"Lượng nước (L)\"],\n    \"data\": [ waterLog.map(function(w){return w.liters;}) ],\n    \"labels\": waterLog.map(function(w){return w.date;})\n}];\n\nmsg.payload = chartData;\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1050,
        "y": 700,
        "wires": [
            [
                "chart_water_daily"
            ]
        ]
    },
