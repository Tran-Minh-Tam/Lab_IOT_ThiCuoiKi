    {
        "id": "fn_water_timer",
        "type": "function",
        "z": "01122f8bf11e4369",
        "name": "Timer Logic",
        "func": "var duration = flow.get('water_duration') || 10;\nmsg.payload = \"ON\";\nnode.send(msg);\n\nsetTimeout(function() {\n    node.send({payload: \"OFF\", topic: \"tuoicay/manual\"});\n}, duration * 1000);\n\nreturn null;",
